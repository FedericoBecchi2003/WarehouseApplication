# ========================================
# AMBIENTE E CONFIGURAZIONE GENERALE
# ========================================
ASPNETCORE_ENVIRONMENT=Production
DOTNET_ENVIRONMENT=Production

# ========================================
# DOCKER HUB CREDENTIALS
# ========================================
# Per il GitHub Actions workflow
DOCKERHUB_USERNAME=your_dockerhub_username
DOCKERHUB_TOKEN=your_dockerhub_token

# ========================================
# SERVICE TAGS (per specificare versioni)
# ========================================
ORDER_SERVICE_TAG=latest
PAYMENT_SERVICE_TAG=latest
WAREHOUSE_SERVICE_TAG=latest

# ========================================
# GITHUB CREDENTIALS (per NuGet packages)
# ========================================
# Token con permesso read:packages
GITHUB_TOKEN=your_github_pat_token

# ========================================
# DATABASE - ORDER SERVICE
# ========================================
ORDER_DB_USER=ecommerce_user
ORDER_DB_PASSWORD=SecurePassword123!
ORDER_DB_NAME=order_db
ORDER_DB_HOST=order-db
ORDER_DB_PORT=5432

# ========================================
# DATABASE - PAYMENT SERVICE
# ========================================
PAYMENT_DB_USER=ecommerce_user
PAYMENT_DB_PASSWORD=SecurePassword123!
PAYMENT_DB_NAME=payment_db
PAYMENT_DB_HOST=payment-db
PAYMENT_DB_PORT=5432

# ========================================
# DATABASE - WAREHOUSE SERVICE
# ========================================
WAREHOUSE_DB_USER=ecommerce_user
WAREHOUSE_DB_PASSWORD=SecurePassword123!
WAREHOUSE_DB_NAME=warehouse_db
WAREHOUSE_DB_HOST=warehouse-db
WAREHOUSE_DB_PORT=5432

# ========================================
# KAFKA CONFIGURATION
# ========================================
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_BROKER_HOST=kafka
KAFKA_BROKER_PORT=29092
KAFKA_PUBLIC_PORT=9092

# ========================================
# API PORTS
# ========================================
ORDER_SERVICE_PORT=5001
PAYMENT_SERVICE_PORT=5003
WAREHOUSE_SERVICE_PORT=5002

# ========================================
# LOG CONFIGURATION
# ========================================
LOG_LEVEL=Information
LOGGING__LOGLEVEL__DEFAULT=Information
LOGGING__LOGLEVEL__MICROSOFT=Warning

# ========================================
# ADVANCED SETTINGS
# ========================================
# Per deployment in produzione, modifica:
# - ASPNETCORE_ENVIRONMENT=Production
# - Usa credenziali sicure (non hard-coded)
# - Abilita HTTPS
# - Configura logging appropriatamente
